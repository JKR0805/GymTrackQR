VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Cloud Function URLs — leave empty to use relative paths (works with Firebase Hosting rewrites)
# Set these when deploying to Vercel or when functions are hosted separately.
# e.g. https://us-central1-YOUR_PROJECT.cloudfunctions.net/generateSignedQr
VITE_GENERATE_QR_URL=
# e.g. https://us-central1-YOUR_PROJECT.cloudfunctions.net/validateScan
VITE_VALIDATE_SCAN_URL=

# Path to Firebase service account key (for seed scripts only, not bundled into client)
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json
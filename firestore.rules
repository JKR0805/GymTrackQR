rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    function isOwner(userId) {
      return isSignedIn() && uid() == userId;
    }

    function userRole(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data.role;
    }

    function isAdmin() {
      return isSignedIn() && userRole(uid()) == 'admin';
    }

    function isDateKey(value) {
      return value is string && value.matches('^\\d{4}-\\d{2}-\\d{2}$');
    }

    function isTime24(value) {
      return value is string && value.matches('^([01]\\d|2[0-3]):[0-5]\\d$');
    }

    function isDuration(value) {
      // Expected format: "<hours>h <minutes>m" (e.g., "1h 5m")
      return value is string && value.matches('^\\d+h \\d+m$');
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /members/{memberId} {
      allow get: if isOwner(memberId) || isAdmin();
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /qrCodes/{qrId} {
      // Members only ever need the single active doc.
      allow get: if isSignedIn() && qrId == 'active';
      allow list: if false;

      allow create, update: if isAdmin() &&
        qrId == 'active' &&
        request.resource.data.id == 'active' &&
        request.resource.data.type == 'gym-checkin' &&
        request.resource.data.version == 1 &&
        request.resource.data.token is string &&
        request.resource.data.isActive == true;

      allow delete: if isAdmin();
    }

    match /attendance/{attendanceId} {
      allow read: if isSignedIn() && (isAdmin() || resource.data.memberId == uid());

      allow create: if isSignedIn() && (
        isAdmin() ||
        (
          request.resource.data.memberId == uid() &&
          request.resource.data.memberName is string &&
          request.resource.data.qrCodeId == 'active' &&
          isDateKey(request.resource.data.date) &&
          isTime24(request.resource.data.entryTime) &&
          request.resource.data.exitTime == null &&
          request.resource.data.duration == null &&
          request.resource.data.timestamp is timestamp
        )
      );

      // Two permitted member update modes:
      // 1) Close an open session (set exitTime + duration + updatedAt)
      // 2) Mark a *closed* session as autoClosed=true (used when the app auto-closes stale sessions)
      allow update: if isSignedIn() && (
        isAdmin() ||
        (
          // (1) close an open session
          resource.data.memberId == uid() &&
          resource.data.exitTime == null &&
          request.resource.data.diff(resource.data).changedKeys().hasOnly(['exitTime', 'duration', 'updatedAt', 'autoClosed']) &&
          request.resource.data.memberId == resource.data.memberId &&
          request.resource.data.memberName == resource.data.memberName &&
          request.resource.data.date == resource.data.date &&
          request.resource.data.qrCodeId == resource.data.qrCodeId &&
          request.resource.data.entryTime == resource.data.entryTime &&
          isTime24(request.resource.data.exitTime) &&
          isDuration(request.resource.data.duration) &&
          request.resource.data.updatedAt is timestamp &&
          (request.resource.data.autoClosed == null || request.resource.data.autoClosed is bool)
        ) ||
        (
          // (2) tag an already closed session as autoClosed=true
          resource.data.memberId == uid() &&
          resource.data.exitTime is string &&
          request.resource.data.diff(resource.data).changedKeys().hasOnly(['autoClosed']) &&
          request.resource.data.autoClosed == true &&
          resource.data.autoClosed != true
        )
      );

      allow delete: if isAdmin();
    }
  }
}

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function userRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isSignedIn() && userRole() == 'admin';
    }

    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /members/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow write: if isAdmin();
    }

    match /qrCodes/{qrId} {
      allow read: if isSignedIn() && qrId == 'active';

      allow create, update: if isAdmin() &&
        qrId == 'active' &&
        request.resource.data.id == 'active' &&
        request.resource.data.type == 'gym-checkin' &&
        request.resource.data.version == 1 &&
        request.resource.data.token is string &&
        request.resource.data.isActive == true;

      allow delete: if isAdmin();
    }

    match /attendance/{attendanceId} {
      allow read: if isSignedIn() && (isAdmin() || resource.data.memberId == request.auth.uid);

      allow create: if isSignedIn() && (
        isAdmin() ||
        (
          request.resource.data.memberId == request.auth.uid &&
          request.resource.data.memberName is string &&
          request.resource.data.qrCodeId == 'active' &&
          request.resource.data.date is string &&
          request.resource.data.entryTime is string &&
          request.resource.data.exitTime == null &&
          request.resource.data.duration == null
        )
      );

      allow update: if isSignedIn() && (
        isAdmin() ||
        (
          resource.data.memberId == request.auth.uid &&
          resource.data.exitTime == null &&
          request.resource.data.memberId == resource.data.memberId &&
          request.resource.data.memberName == resource.data.memberName &&
          request.resource.data.date == resource.data.date &&
          request.resource.data.qrCodeId == resource.data.qrCodeId &&
          request.resource.data.entryTime == resource.data.entryTime &&
          request.resource.data.exitTime is string &&
          request.resource.data.duration is string
        )
      );

      allow delete: if isAdmin();
    }
  }
}
